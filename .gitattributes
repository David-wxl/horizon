# 自动检测文本文件并标准化行尾符
* text=auto

# 源代码文件
*.java text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.vue text eol=lf
*.css text eol=lf
*.html text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sql text eol=lf

# 配置文件
.gitignore text eol=lf
.gitattributes text eol=lf
*.properties text eol=lf

# Windows 脚本
*.bat text eol=crlf
*.cmd text eol=crlf

# 二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.jar binary
*.war binary
*.class binary
